PORT=5001
# Local direct Supabase connection can use db.<project-ref>.supabase.co.
# Render should use the Supabase connection pooler because Render may not reach Supabase IPv6 direct DB hosts.
# Get this from Supabase Dashboard > Project Settings > Database > Connection string > Transaction pooler.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:6543/postgres
JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://skillcase-intern-assessment.vercel.app
